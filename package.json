    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "googleapis": "^171.4.0",
    "joi": "^18.1.2",
